{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "$app/environment": ["./src/stubs/app-environment.ts"],
      "$lib/client/toaster": ["./src/stubs/toaster.ts"],
      "$lib/client/utils": ["./src/stubs/client-utils.ts"],
      "$lib/shared/*": ["../src/lib/shared/*"],
      "$lib/*": ["../src/lib/*"]
    }
  },
  "include": ["src/**/*.ts"],
  // Shared source files are compiled by Vite with aliases — excluding them from tsc
  // avoids pulling in their unresolvable npm dependencies (fluent-ffmpeg, onnxruntime-node).
  "exclude": ["node_modules", "../src/lib/shared"]
}
